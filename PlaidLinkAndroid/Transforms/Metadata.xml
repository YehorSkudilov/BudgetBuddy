<metadata>

	<!-- ========================================================= -->
	<!-- 1. REMOVE INTERNAL PLAID IMPLEMENTATION -->
	<!-- ========================================================= -->
	<remove-node path="/api/package[starts-with(@name, 'com.plaid.internal')]" />

	<!-- ========================================================= -->
	<!-- 2. FIX ENUM CS0542 ROOT CAUSE (ONLY TARGET REAL BUG) -->
	<!-- ========================================================= -->

	<!-- Remove ONLY broken OTHER enum branch -->
	<remove-node path="/api/package[@name='com.plaid.link.result']//class[@name='LinkAccountSubtype.OTHER']" />

	<remove-node path="/api/package[@name='com.plaid.link.result']//class[contains(@name,'OTHERInvoker')]" />

	<!-- ========================================================= -->
	<!-- 3. SAFE FIELD RENAMES ONLY (NO WILDCARDS ON CLASS NAME) -->
	<!-- ========================================================= -->

	<attr path="/api/package//class[@name='LinkResult']//field[@name='LinkResult']"
		  name="name">LinkResultValue</attr>

	<!-- ========================================================= -->
	<!-- 4. FIX DUPLICATE NESTED TYPES -->
	<!-- ========================================================= -->

	<attr path="/api/package[starts-with(@name, 'com.plaid.link')]//class[@name='Creator']"
		  name="name">LinkCreator</attr>

	<attr path="/api/package[starts-with(@name, 'com.plaid.link')]//class[@name='Companion']"
		  name="name">LinkCompanion</attr>

	<!-- ========================================================= -->
	<!-- 5. PARCELABLE FIX -->
	<!-- ========================================================= -->

	<attr path="/api/package[starts-with(@name, 'com.plaid.link')]//method[@name='createFromParcel']"
		  name="managedReturn">Java.Lang.Object</attr>

	<attr path="/api/package[starts-with(@name, 'com.plaid.link')]//method[@name='newArray']"
		  name="managedReturn">Java.Lang.Object[]</attr>

	<!-- ========================================================= -->
	<!-- 6. EXCEPTION FIX -->
	<!-- ========================================================= -->

	<attr path="/api/package[@name='com.plaid.link.exception']/class[@name='LinkInvalidResultException']"
		  name="extends">java.lang.Exception</attr>

</metadata>