<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             xmlns:local="clr-namespace:BudgetBuddy"
             x:Class="BudgetBuddy.CAppShell"
             Loaded="ContentPage_Loaded">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#008060" Offset="0.0" />
            <GradientStop Color="#001a13" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <!-- ROOT -->
    <Grid>

        <!-- MAIN APP -->
        <Grid Padding="10" x:Name="MainGrid" RowDefinitions="auto, *, 25.5, 25.5">

            <local:TopBar x:Name="TopBar"
                          SettingsAction="{Binding SettingsAction}"
                          NotificationsAction="{Binding NotificationsAction}"
                          Margin="0,0,0,10"
                          PageName="{Binding PageName}"/>

            <AppSkeleton:CView Grid.Row="1" Grid.RowSpan="2" x:Name="View"/>

            <AppSkeleton:CNavBar x:Name="NavBar"
                                 Grid.Row="2"
                                 Grid.RowSpan="2"
                                 FontFamily="OutlinedIcons"
                                 SelectedFontFamily="RegularIcons"
                                 CNavIconItems="{Binding CNavIconItems}"/>
        </Grid>

        <!-- 🔐 AUTH OVERLAY -->
        <Grid x:Name="AuthContainer"
      IsVisible="False"/>

    </Grid>
</ContentPage>