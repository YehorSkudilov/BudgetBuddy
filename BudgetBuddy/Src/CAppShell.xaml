<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             xmlns:local="clr-namespace:BudgetBuddy"
             x:Class="BudgetBuddy.CAppShell">
    <Grid Padding="10" x:Name="MainGrid" RowSpacing="10" RowDefinitions="auto, *, auto">
        <local:TopBar PageName="{Binding PageName}"/>
        <AppSkeleton:CView Grid.Row="1" x:Name="View"/>
        <AppSkeleton:CNavBar x:Name="NavBar" Grid.Row="2" FontFamily="OutlinedIcons" SelectedFontFamily="RegularIcons" CNavIconItems="{Binding CNavIconItems}"/>
    </Grid>
</ContentPage>