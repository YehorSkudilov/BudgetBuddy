<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetBuddy.MainPage">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">

        <VerticalStackLayout Spacing="15">

            <Button
                x:Name="PlaidBtn"
                Text="Connect Bank"
                Clicked="OnPlaidClicked" />

            <Label
                x:Name="ResultLabel"
                Text="Result will show here" />

        </VerticalStackLayout>

        <!-- WebView -->
        <WebView
            x:Name="PlaidWebView"
            IsVisible="False"
            Grid.Row="1" />

        <!-- Transactions -->
        <CollectionView
            x:Name="TransactionsView"
            Grid.Row="2">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontAttributes="Bold"/>
                            <Label Text="{Binding Amount}" />
                            <Label Text="{Binding Date}" FontSize="12"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>