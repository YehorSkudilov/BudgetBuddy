<?xml version="1.0" encoding="utf-8" ?>
<local:CContentView
    x:Class="BudgetBuddy.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
    xmlns:local="clr-namespace:BudgetBuddy"
    BackgroundColor="Transparent">

    <Grid>
        <ScrollView>

            <VerticalStackLayout Spacing="10">


                <AppSkeleton:CButton
                    Clicked="CButton_Clicked"
                    HeightRequest="80"
                    Icon="sync"
                    IconFontFamily="OutlinedIcons"
                    IconHeightRequest="30"
                    IconWidthRequest="30" />

                <AppSkeleton:CButton
                    Clicked="OnLogoutClicked"
                    HeightRequest="60"
                    Icon="logout"
                    IconFontFamily="OutlinedIcons" />


                <AppSkeleton:AcrylicView
                    BorderColor="#40ffffff"
                    CornerRadius="25"
                    EffectStyle="Custom"
                    TintColor="#20ffffff"
                    TintOpacity=".5">


                    <VerticalStackLayout Padding="15" Spacing="5">

                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Account"
                            TextColor="White" />

                        <Grid Padding="5" ColumnDefinitions="Auto,*">
                            <Label Text="Profile" TextColor="#ccffffff" />
                            <Label
                                Grid.Column="1"
                                HorizontalOptions="End"
                                Text="&gt;"
                                TextColor="#88ffffff" />
                        </Grid>

                        <Grid Padding="5" ColumnDefinitions="Auto,*">
                            <Label Text="Security" TextColor="#ccffffff" />
                            <Label
                                Grid.Column="1"
                                HorizontalOptions="End"
                                Text="&gt;"
                                TextColor="#88ffffff" />
                        </Grid>

                        <Grid Padding="5" ColumnDefinitions="Auto,*">
                            <Label Text="Payment Methods" TextColor="#ccffffff" />
                            <Label
                                Grid.Column="1"
                                HorizontalOptions="End"
                                Text="&gt;"
                                TextColor="#88ffffff" />
                        </Grid>

                        <Grid Padding="5" ColumnDefinitions="Auto,*">
                            <Label Text="Subscription" TextColor="#ccffffff" />
                            <Label
                                Grid.Column="1"
                                HorizontalOptions="End"
                                Text="&gt;"
                                TextColor="#88ffffff" />
                        </Grid>

                    </VerticalStackLayout>
                </AppSkeleton:AcrylicView>

                <AppSkeleton:AcrylicView
                    BorderColor="#40ffffff"
                    CornerRadius="25"
                    EffectStyle="Custom"
                    TintColor="#20ffffff"
                    TintOpacity=".5">


                    <VerticalStackLayout Padding="15" Spacing="12">

                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="App"
                            TextColor="White" />

                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="Dark Mode" TextColor="#ccffffff" />
                            <Switch Grid.Column="1" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="Notifications" TextColor="#ccffffff" />
                            <Switch Grid.Column="1" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="Haptic Feedback" TextColor="#ccffffff" />
                            <Switch Grid.Column="1" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="Auto Sync" TextColor="#ccffffff" />
                            <Switch Grid.Column="1" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="Show Animations" TextColor="#ccffffff" />
                            <Switch Grid.Column="1" HorizontalOptions="End" />
                        </Grid>

                    </VerticalStackLayout>
                </AppSkeleton:AcrylicView>


                <AppSkeleton:AcrylicView
                    Margin="0,0,0,30"
                    BorderColor="#40ffffff"
                    CornerRadius="25"
                    EffectStyle="Custom"
                    TintColor="#20ffffff"
                    TintOpacity=".5">


                    <VerticalStackLayout Padding="15" Spacing="8">

                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="About"
                            TextColor="White" />

                        <Label Text="BudgetBuddy v1.0" TextColor="#ccffffff" />

                        <Label
                            FontSize="12"
                            Text="Built with .NET MAUI"
                            TextColor="#88ffffff" />

                        <Label
                            FontSize="12"
                            Text="Privacy Policy"
                            TextColor="#88ffffff" />

                        <Label
                            FontSize="12"
                            Text="Terms of Service"
                            TextColor="#88ffffff" />

                    </VerticalStackLayout>

                </AppSkeleton:AcrylicView>
            </VerticalStackLayout>

        </ScrollView>

    </Grid>
</local:CContentView>