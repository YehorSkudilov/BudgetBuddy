<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BudgetBuddy.LoadingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="Black">

    <Grid>
        <VerticalStackLayout
            Spacing="20"
            VerticalOptions="Center"
            HorizontalOptions="Center">

            <!-- App Name / Logo -->
            <Label
                Text="BudgetBuddy"
                FontSize="28"
                TextColor="White"
                HorizontalOptions="Center" />

            <!-- Loading Spinner -->
            <ActivityIndicator
                IsRunning="True"
                Color="White"
                WidthRequest="40"
                HeightRequest="40" />

        </VerticalStackLayout>
    </Grid>

</ContentPage>