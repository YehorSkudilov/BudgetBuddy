<?xml version="1.0" encoding="utf-8" ?>
<local:CContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BudgetBuddy"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             
             x:Class="BudgetBuddy.HomePage">
    <Grid x:Name="MainGrid" RowSpacing="10" RowDefinitions="60, 180, auto, *">

        <Grid Grid.Row="0">
            <local:StatsView Stats="{Binding Stats}" />
        </Grid>




        <AppSkeleton:AcrylicView
                Grid.Row="1"
                EffectStyle="Custom"    
                TintColor="#20ffffff"
                BorderColor="#40ffffff"
                Padding="10"
                TintOpacity=".5"  
                CornerRadius="25">

            <Grid RowDefinitions="auto,auto,*" RowSpacing="5">
                <Label
        HorizontalOptions="Center"
        Text="Net Worth" />
   
                <BoxView Grid.Row="1" HeightRequest="1" />
                <AppSkeleton:CChart Grid.Row="2">
                    <AppSkeleton:CChart.Chart>
                        <AppSkeleton:CBarChart IsHorizontal="False" Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.MoneyValues}"/>
                    </AppSkeleton:CChart.Chart>
                </AppSkeleton:CChart>
            </Grid>
        </AppSkeleton:AcrylicView>



        <AppSkeleton:AcrylicView Grid.Row="2" CornerRadius="25" Padding="15" EffectStyle="Custom" TintColor="#20ffffff" TintOpacity=".5" BorderColor="#40ffffff">
            <VerticalStackLayout Spacing="10">
                <Grid>
                <Label Text="Budget Progress" VerticalOptions="Center" FontAttributes="Bold" TextColor="White"/>

                    <Button VerticalOptions="Center" Grid.Column="1" Text="See All" HorizontalOptions="End" Padding="1" MinimumHeightRequest="0" MinimumWidthRequest="0" FontSize="12" BackgroundColor="Transparent" TextColor="#88ffffff"/>

                </Grid>
                <VerticalStackLayout Spacing="2">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Food &amp; Dining" FontSize="12" TextColor="#ccffffff"/>
                        <Label Grid.Column="1" Text="$450 / $600" FontSize="12" TextColor="#ccffffff"/>
                    </Grid>
                    <ProgressBar Progress="0.75" ProgressColor="#4CD964" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="2">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Entertainment" FontSize="12" TextColor="#ccffffff"/>
                        <Label Grid.Column="1" Text="$180 / $200" FontSize="12" TextColor="#ccffffff"/>
                    </Grid>
                    <ProgressBar Progress="0.9" ProgressColor="#FFCC00" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </AppSkeleton:AcrylicView>

        <Grid Grid.Row="3" RowDefinitions="Auto, *">
            <Grid ColumnDefinitions="*, Auto">
                <Label Text="Recent Transactions" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                <Button Grid.Column="1" Text="See All" FontSize="12" BackgroundColor="Transparent" TextColor="#88ffffff"/>
                <BoxView HeightRequest="1" Grid.ColumnSpan="2" VerticalOptions="End"/>
            </Grid>
            <Grid Grid.Row="1" IsClippedToBounds="True" Padding="0,-10,0,0">
                <local:TransactionListView IsClippedToBounds="True" Items="{Binding RecentTransactions}" />
            </Grid>
        </Grid>

    </Grid>
</local:CContentView>