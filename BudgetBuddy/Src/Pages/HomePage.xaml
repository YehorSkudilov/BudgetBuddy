<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             
             x:Class="BudgetBuddy.HomePage">
    <Grid x:Name="MainGrid" RowDefinitions="180, *">

        <Grid Grid.Row="1">
            <AppSkeleton:CChart>
                <AppSkeleton:CChart.Chart>
                    <AppSkeleton:CLineChart Smooth="True" Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}"/>
                </AppSkeleton:CChart.Chart>
            </AppSkeleton:CChart>
        </Grid>
        
        
            <AppSkeleton:AcrylicView
                EffectStyle="Custom"    
                TintColor="#20ffffff"
                BorderColor="#40ffffff"
                Padding="10"
                TintOpacity=".5"  
                CornerRadius="25">

            <Grid RowDefinitions="auto,auto,*" RowSpacing="5">
                <Label
        HorizontalOptions="Center"
        Text="Net Worth" />
   
                <BoxView Grid.Row="1" HeightRequest="1" />
                <AppSkeleton:CChart Grid.Row="2">
                    <AppSkeleton:CChart.Chart>
                        <AppSkeleton:CBarChart IsHorizontal="False" Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.MoneyValues}"/>
                    </AppSkeleton:CChart.Chart>
                </AppSkeleton:CChart>
            </Grid>
        </AppSkeleton:AcrylicView>


    </Grid>
</ContentView>