<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             xmlns:acrylic="clr-namespace:Xe.AcrylicView;assembly=Xe.AcrylicView"
             x:Class="BudgetBuddy.HomePage">
    <Grid x:Name="MainGrid" RowDefinitions="150, *">
        <acrylic:AcrylicView
           Padding="10"
            EffectStyle="Custom"    
                TintColor="#20ffffff"
            BorderColor="#40ffffff"
                        Margin="0,0,0,10"
                TintOpacity=".5"  
                CornerRadius="25">

            <Grid>
                <AppSkeleton:CChart>
                    <AppSkeleton:CChart.Chart>
                        <AppSkeleton:CBarChart IsHorizontal="False" Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.MoneyValues}"/>
                    </AppSkeleton:CChart.Chart>
                </AppSkeleton:CChart>
            </Grid>
        </acrylic:AcrylicView>

        <Grid Grid.Row="1">
            <AppSkeleton:CChart>
                <AppSkeleton:CChart.Chart>
                    <AppSkeleton:CLineChart Smooth="True" Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}"/>
                </AppSkeleton:CChart.Chart>
            </AppSkeleton:CChart>
        </Grid>
    </Grid>
</ContentView>
