<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             xmlns:local="clr-namespace:BudgetBuddy"
             x:Class="BudgetBuddy.BanksPage">
    <Grid RowDefinitions="200, auto, *">
        <Border Padding="10" Stroke="#40ffffff" StrokeThickness="1" Margin="0,0,0,10" Background="#20ffffff">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30"/>
            </Border.StrokeShape>

            <Grid RowSpacing="5" RowDefinitions="auto,auto,*" >
                <Label HorizontalOptions="Center" Text="Payment Alerts"/>
                <BoxView HeightRequest="1" Grid.Row="1"/>
                <local:PaymentAlertsView Grid.Row="2"/>
            </Grid>
        </Border>

        <AppSkeleton:CButton Margin="5,0"  IconPadding="8" IconHeightRequest="30" IconFontFamily="OutlinedIcons" Icon="add" Grid.Row="1"/>

        <local:BankListView Margin="5,0" Grid.Row="2"/>
    </Grid>
</ContentView>
