<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             xmlns:local="clr-namespace:BudgetBuddy"
             xmlns:acrylic="clr-namespace:Xe.AcrylicView;assembly=Xe.AcrylicView"
             x:Class="BudgetBuddy.BanksPage">
    <Grid RowDefinitions="200, 25, 25, *">
        <Grid Padding="10" Margin="0,0,0,10">
            <acrylic:AcrylicView
                EffectStyle="Custom"    
                TintColor="#20ffffff"
            BorderColor="#40ffffff"
                TintOpacity=".5"  
                CornerRadius="25"/>


            <Grid RowSpacing="5" RowDefinitions="auto,auto,*" >
                    <Label HorizontalOptions="Center" Text="Payment Alerts"/>
                    <BoxView HeightRequest="1" Grid.Row="1"/>
                    <local:PaymentAlertsView Grid.Row="2"/>
                </Grid>
        </Grid>

        <local:BankListView Margin="5,0" Grid.Row="2" Grid.RowSpan="2"/>

        <AppSkeleton:CButton IconPadding="8" Margin="5,0"  IconHeightRequest="30" IconFontFamily="OutlinedIcons" Icon="add" Grid.Row="1" Grid.RowSpan="2"/>

    </Grid>
</ContentView>
