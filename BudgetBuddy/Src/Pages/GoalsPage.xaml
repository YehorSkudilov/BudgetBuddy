<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             xmlns:local="clr-namespace:BudgetBuddy"
             xmlns:acrylic="clr-namespace:Xe.AcrylicView;assembly=Xe.AcrylicView"
             x:Class="BudgetBuddy.GoalsPage">
    <Grid x:Name="MainGrid" RowDefinitions="90, *">
        <acrylic:AcrylicView
            Padding="10"
                EffectStyle="Custom"    
                TintColor="#20ffffff"
            BorderColor="#40ffffff"
                        Margin="0,0,0,10"
                TintOpacity=".5"  
                CornerRadius="25">


            <Grid Grid.Row="1">
                <AppSkeleton:CChart>
                    <AppSkeleton:CChart.Chart>
                        <AppSkeleton:CSegmentedBarChart CornerRadius="16" Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}"/>
                    </AppSkeleton:CChart.Chart>
                </AppSkeleton:CChart>
            </Grid>
        </acrylic:AcrylicView>

    </Grid>
</ContentView>
