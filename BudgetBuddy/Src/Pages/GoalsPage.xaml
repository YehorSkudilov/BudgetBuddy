<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="BudgetBuddy.GoalsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
    xmlns:local="clr-namespace:BudgetBuddy">
    <Grid x:Name="MainGrid" RowDefinitions="90, *">
        <AppSkeleton:AcrylicView
            Padding="10"
            BorderColor="#40ffffff"
            CornerRadius="25"
            EffectStyle="Custom"
            TintColor="#20ffffff"
            TintOpacity=".5">



            <Grid Grid.Row="1">
                <AppSkeleton:CChart>
                    <AppSkeleton:CChart.Chart>
                        <AppSkeleton:CSegmentedBarChart CornerRadius="16" Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}" />
                    </AppSkeleton:CChart.Chart>
                </AppSkeleton:CChart>
            </Grid>
        </AppSkeleton:AcrylicView>

    </Grid>
</ContentView>
