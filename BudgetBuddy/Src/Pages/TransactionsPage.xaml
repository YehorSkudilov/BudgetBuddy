<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BudgetBuddy"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             x:Class="BudgetBuddy.TransactionsPage">
    <Grid x:Name="MainGrid" RowDefinitions="150, auto, *">
        <Border Padding="10" Stroke="#40ffffff" StrokeThickness="1" Background="#20ffffff">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30"/>
            </Border.StrokeShape>

            <Grid>
                <AppSkeleton:CChart>
                    <AppSkeleton:CChart.Chart>
                        <AppSkeleton:CBarChart IsHorizontal="False" Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}"/>
                    </AppSkeleton:CChart.Chart>
                </AppSkeleton:CChart>
            </Grid>
        </Border>

        <Grid Margin="0,10,5,0" ColumnDefinitions="*, auto" ColumnSpacing="10" Grid.Row="1">
            <Grid IsClippedToBounds="True">
                <SearchBar Margin="{OnPlatform Android='-10,0,0,0', Default='10,0,0,0'}" Placeholder="Search transactions..."/>
                <BoxView IsVisible="{OnPlatform Android='True', Default='False'}"  HeightRequest="1" VerticalOptions="End"/>

            </Grid>
            <Image VerticalOptions="Center" Grid.Column="1" HorizontalOptions="End">
                <Image.Source>
                    <FontImageSource FontFamily="RegularIcons" Glyph="filter_list"/>
                </Image.Source>
            </Image>


        </Grid>

        <local:TransactionListView Grid.Row="2" Items="{Binding TransactionsGroups}" />
    </Grid>
</ContentView>
