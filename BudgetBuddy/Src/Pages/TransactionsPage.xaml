<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="BudgetBuddy.TransactionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
    xmlns:local="clr-namespace:BudgetBuddy">
    <Grid x:Name="MainGrid" RowDefinitions="150, auto, *">
        <Grid>
            <AppSkeleton:AcrylicView
                Padding="10"
                BorderColor="#40ffffff"
                CornerRadius="25"
                EffectStyle="Custom"
                TintColor="#20ffffff"
                TintOpacity=".5">

                <AppSkeleton:CChart>
                    <AppSkeleton:CChart.Chart>
                        <AppSkeleton:CBarChart Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}" IsHorizontal="False" />
                    </AppSkeleton:CChart.Chart>
                </AppSkeleton:CChart>
            </AppSkeleton:AcrylicView>
        </Grid>

        <Grid
            Grid.Row="1"
            Margin="0,10,5,0"
            ColumnDefinitions="*, auto"
            ColumnSpacing="10">
            <Grid IsClippedToBounds="True">
                <SearchBar Margin="{OnPlatform Android='-10,0,0,0', Default='10,0,0,0'}" Placeholder="Search transactions..." />
                <BoxView
                    HeightRequest="1"
                    IsVisible="{OnPlatform Android='True',
                                           Default='False'}"
                    VerticalOptions="End" />

            </Grid>
            <Image
                Grid.Column="1"
                HorizontalOptions="End"
                VerticalOptions="Center">
                <Image.Source>
                    <FontImageSource FontFamily="RegularIcons" Glyph="filter_list" />
                </Image.Source>
            </Image>


        </Grid>

        <local:TransactionListView Grid.Row="2" Items="{Binding TransactionsGroups}" />
    </Grid>
</ContentView>
