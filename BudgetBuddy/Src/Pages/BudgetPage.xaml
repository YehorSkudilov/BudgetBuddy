<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             x:Class="BudgetBuddy.BudgetPage">
    <Grid x:Name="MainGrid" RowDefinitions=".4*, *">
        <Border Stroke="#40ffffff" StrokeThickness="1" Background="#20ffffff">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30"/>
            </Border.StrokeShape>
        </Border>

        <Grid Grid.Row="1">
            <AppSkeleton:CChart>
                <AppSkeleton:CChart.Chart>
                    <AppSkeleton:CPieChart Values="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}"/>
                </AppSkeleton:CChart.Chart>
            </AppSkeleton:CChart>
        </Grid>
    </Grid>

  
</ContentView>
