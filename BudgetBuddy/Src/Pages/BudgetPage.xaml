<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             xmlns:local="clr-namespace:BudgetBuddy"
             x:Class="BudgetBuddy.BudgetPage">
    <Grid x:Name="MainGrid" RowDefinitions="200, auto, *">
        <Border Padding="10" Stroke="#40ffffff" Margin="0,0,0,10" StrokeThickness="1" Background="#20ffffff">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30"/>
            </Border.StrokeShape>
            
                    <Grid>
            <AppSkeleton:CChart>
                <AppSkeleton:CChart.Chart>
                    <AppSkeleton:CPieChart Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}"/>
                </AppSkeleton:CChart.Chart>
            </AppSkeleton:CChart>
        </Grid>
        </Border>

        <AppSkeleton:CButton IconPadding="8" IconHeightRequest="30" IconFontFamily="OutlinedIcons" Icon="add" Grid.Row="1"/>


        <local:BudgetListView Grid.Row="2"/>

    </Grid>

  
</ContentView>
