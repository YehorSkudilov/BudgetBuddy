<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="BudgetBuddy.BudgetPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
    xmlns:local="clr-namespace:BudgetBuddy">
    <Grid x:Name="MainGrid" RowDefinitions="200, 25, 25, *">
        <AppSkeleton:AcrylicView
            Margin="0,0,0,10"
            Padding="10"
            BorderColor="#40ffffff"
            CornerRadius="30"
            EffectStyle="Custom"
            TintColor="#20ffffff"
            TintOpacity=".5">

            <AppSkeleton:CChart>
                <AppSkeleton:CChart.Chart>
                    <AppSkeleton:CPieChart Entries="{Binding Source={x:Reference MainGrid}, Path=BindingContext.Values}" />
                </AppSkeleton:CChart.Chart>
            </AppSkeleton:CChart>
        </AppSkeleton:AcrylicView>


        <local:BudgetListView
            Grid.Row="2"
            Grid.RowSpan="2"
            Margin="5,0" />

        <AppSkeleton:CButton
            Grid.Row="1"
            Grid.RowSpan="2"
            Margin="5,0"
            Icon="add"
            IconFontFamily="OutlinedIcons"
            IconHeightRequest="30"
            IconPadding="8" />


    </Grid>


</ContentView>
