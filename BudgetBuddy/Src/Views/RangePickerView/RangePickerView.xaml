<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetBuddy.RangePickerView">
    <Grid x:Name="MainGrid">
        <HorizontalStackLayout>
            <HorizontalStackLayout>
                <DatePicker/>
                <TimePicker/>
            </HorizontalStackLayout>
            
            <Image>
                <Image.Source>
                    <FontImageSource Size="20" FontFamily="RegularIcons" Glyph="arrow_forward"/>
                </Image.Source>
            </Image>

            <HorizontalStackLayout>
                <DatePicker/>
                <TimePicker/>
            </HorizontalStackLayout>
        </HorizontalStackLayout>
    </Grid>
</ContentView>
