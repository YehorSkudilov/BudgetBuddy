<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="BudgetBuddy.BankListView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
    BackgroundColor="Transparent">

    <ContentView.Resources>
        <ResourceDictionary>

            <AppSkeleton:BoolToIconConverter
                x:Key="ExpandIconConverter"
                FalseIcon="arrow_drop_down"
                TrueIcon="arrow_drop_up" />

        </ResourceDictionary>
    </ContentView.Resources>

    <Grid x:Name="MainGrid">
        <CollectionView ItemsSource="{Binding BankItems}">

            <CollectionView.HeaderTemplate>
                <DataTemplate>

                    <Grid Margin="0,30,0,0" />

                </DataTemplate>
            </CollectionView.HeaderTemplate>

            <CollectionView.FooterTemplate>
                <DataTemplate>

                    <Grid Margin="0,25,0,0" />

                </DataTemplate>
            </CollectionView.FooterTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <AppSkeleton:AcrylicView
                            Margin="0,0,0,10"
                            BorderColor="#40ffffff"
                            CornerRadius="25"
                            EffectStyle="Custom"
                            TintColor="#20ffffff"
                            TintOpacity=".5">


                            <VerticalStackLayout Padding="12" Spacing="10">

                                <!--  BANK HEADER (CLICKABLE)  -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                                    <HorizontalStackLayout Spacing="10">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            Text="{Binding BankName}"
                                            TextColor="White"
                                            VerticalOptions="Center" />

                                        <BoxView
                                            Background="#40ffffff"
                                            HeightRequest="20"
                                            WidthRequest="1" />

                                        <Label
                                            FontSize="14"
                                            Text="{Binding TotalBalance}"
                                            TextColor="#ccffffff"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Grid.Column="1" Spacing="10">


                                        <AppSkeleton:CButton
                                            CButtonBackgroundColor="Transparent"
                                            CButtonStroke="Transparent"
                                            Icon="delete"
                                            IconFontFamily="OutlinedIcons" />

                                        <AppSkeleton:CButton
                                            CButtonBackgroundColor="Transparent"
                                            CButtonStroke="Transparent"
                                            IsBackgroundVisible="False"
                                            Icon="{Binding IsExpanded, Converter={StaticResource ExpandIconConverter}}"
                                            IconFontFamily="OutlinedIcons"
                                            InputTransparent="True" />

                                    </HorizontalStackLayout>


                                    <!--  TAP TO EXPAND  -->
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBankTapped" />
                                    </Grid.GestureRecognizers>
                                </Grid>

                                <!--  ACCOUNTS LIST (HIDDEN UNTIL EXPANDED)  -->
                                <CollectionView
                                    IsVisible="{Binding IsExpanded}"
                                    ItemsSource="{Binding Accounts}"
                                    SelectionMode="None">

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>

                                            <Border
                                                Margin="0,5,0,0"
                                                Background="#10ffffff"
                                                Stroke="#30ffffff">

                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="15" />
                                                </Border.StrokeShape>

                                                <Grid
                                                    Padding="10"
                                                    ColumnDefinitions="*,Auto"
                                                    ColumnSpacing="10">

                                                    <VerticalStackLayout>
                                                        <Label
                                                            FontSize="13"
                                                            Text="{Binding Name}"
                                                            TextColor="White" />

                                                        <Label
                                                            FontSize="11"
                                                            Text="{Binding Type}"
                                                            TextColor="#88ffffff" />
                                                    </VerticalStackLayout>

                                                    <Label
                                                        Grid.Column="1"
                                                        Text="{Binding Balance}"
                                                        TextColor="White"
                                                        VerticalOptions="Center" />
                                                </Grid>

                                            </Border>

                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                            </VerticalStackLayout>
                        </AppSkeleton:AcrylicView>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentView>