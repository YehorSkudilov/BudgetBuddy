<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
             x:Class="BudgetBuddy.TopBar">
    <Grid x:Name="MainGrid" Margin="5,0" ColumnDefinitions="auto, *, auto">
        <AppSkeleton:CButton IconFontFamily="OutlinedIcons" IconHeightRequest="30" IconWidthRequest="30" IconPadding="7" Icon="notifications"/>
        <Label HorizontalOptions="Center" VerticalOptions="Center" FontSize="30" Grid.Column="1" Text="{Binding PageName}"/>
        <AppSkeleton:CButton IconFontFamily="OutlinedIcons" Grid.Column="2" IconHeightRequest="30" IconWidthRequest="30" IconPadding="7" Icon="settings"/>

    </Grid>
</ContentView>
