<?xml version="1.0" encoding="utf-8" ?>
<local:CContentView
    x:Class="BudgetBuddy.AuthView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:AppSkeleton="clr-namespace:AppSkeleton;assembly=AppSkeleton"
    xmlns:local="clr-namespace:BudgetBuddy">

    <Grid>

        <!-- BACKGROUND -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#008060" Offset="0.0" />
                    <GradientStop Color="#001a13" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- CARD -->
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="15"
            WidthRequest="300">

            <AppSkeleton:AcrylicView
                CornerRadius="25"
                TintColor="#20ffffff"
                TintOpacity=".6"
                BorderColor="#40ffffff">

                <VerticalStackLayout Padding="20" Spacing="15">

                    <Label
                        Text="BudgetBuddy"
                        FontSize="22"
                        HorizontalOptions="Center"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <!-- EMAIL -->
                    <Entry x:Name="EmailEntry"
                           Placeholder="Email"
                           TextColor="White"
                           PlaceholderColor="#88ffffff" />

                    <!-- PASSWORD -->
                    <Entry x:Name="PasswordEntry"
                           Placeholder="Password"
                           IsPassword="True"
                           TextColor="White"
                           PlaceholderColor="#88ffffff" />

                    <!-- CONFIRM PASSWORD -->
                    <Entry x:Name="ConfirmPasswordEntry"
                           Placeholder="Confirm Password"
                           IsPassword="True"
                           TextColor="White"
                           PlaceholderColor="#88ffffff"
                           IsVisible="False" />

 

                    <!-- LOGIN -->
                    <AppSkeleton:CButton
                        x:Name="LoginButton"
                        Text="Login"
                        Clicked="OnLoginClicked"
                        HeightRequest="50" />

                    <!-- REGISTER -->
                    <AppSkeleton:CButton
                        x:Name="RegisterButton"
                        Text="Register"
                        Clicked="OnRegisterClicked"
                        HeightRequest="50"
                        IsVisible="False" />
                    
                                       <!-- STAY LOGGED IN -->
                   <Grid Margin="0,-15" ColumnDefinitions="*,auto,*">
                       <CheckBox HorizontalOptions="Start" Grid.Column="2" x:Name="StayLoggedInCheckBox" IsChecked="true" />
                       <Label Grid.Column="1" Text="Stay logged in"
                              TextColor="#88ffffff"
                              VerticalOptions="Center" />
                   </Grid>

                    <BoxView HeightRequest="1" Background="#88ffffff"/>

                    <!-- TOGGLE -->
                    <Label
                        Text="{Binding ToggleText}"
                        TextColor="#88ffffff"
                        HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleMode" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- ERROR -->
                    <Label x:Name="ErrorLabel"
                           TextColor="#ff8080"
                           FontSize="12"
                           IsVisible="False" />

                </VerticalStackLayout>
            </AppSkeleton:AcrylicView>

        </VerticalStackLayout>
    </Grid>
</local:CContentView>